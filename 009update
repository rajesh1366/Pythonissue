trigger:
- main

pool:
  name: sc-linux-ga

steps:
- checkout: self
  persistCredentials: true

- script: |

    echo "Starting repository sync..."

    FEATURE_BRANCH="feature/API-Integration"
    SOURCE_REPO="52015-test-repo"
    ORG_URL="ado.global.standardchartered.com"
    PROJECT="ASIAQPR"

    echo "Cleaning workspace..."
    rm -rf $SOURCE_REPO

    echo "Cloning source repo..."

    git clone https://$(System.AccessToken)@$ORG_URL/sc-ado-qa-op/$PROJECT/_git/$SOURCE_REPO

    echo "Reading repo list from CSV..."

    tail -n +2 repos.csv | while IFS=, read -r repo
    do
        # Clean repo name
        repo=$(echo "$repo" | tr -d '"' | xargs)

        if [ -z "$repo" ]; then
            continue
        fi

        echo "=============================="
        echo "Processing repo: $repo"
        echo "=============================="

        rm -rf $repo

        echo "Cloning target repo..."
        git clone https://$(System.AccessToken)@$ORG_URL/sc-ado-qa-op/$PROJECT/_git/$repo

        cd $repo

        # Set git identity (LOCAL only)
        git config user.email "ado-bot@sc.com"
        git config user.name "ADO Bot"

        # Create or switch branch
        git checkout -b $FEATURE_BRANCH || git checkout $FEATURE_BRANCH

        echo "Copying files from source repo..."
        cp -r ../$SOURCE_REPO/* .

        git add .

        # Commit only if changes exist
        if ! git diff --cached --quiet; then
            git commit -m "Sync from $SOURCE_REPO"
        else
            echo "No changes to commit"
        fi

        echo "Pushing to $repo..."
        git push origin $FEATURE_BRANCH --force

        cd ..

    done

    echo "Repository sync completed successfully!"

  displayName: Sync source repo to multiple repos using CSV
